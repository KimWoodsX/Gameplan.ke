# GAMEPLAN Server — Environment Variables
# Copy this file to .env and fill in your values before starting the server.
# Never commit your real .env file to version control.

# ── Server ────────────────────────────────────────────────────────────────────
# Port the HTTP server listens on (default: 3000)
PORT=3000

# ── Admin Dashboard ───────────────────────────────────────────────────────────
# Password required to log into the /admin dashboard.
# IMPORTANT: Change this to a long, random string before deploying.
#            The default value "2007" is insecure and triggers a startup warning.
ADMIN_DASHBOARD_KEY=change-me-before-deploying

# ── AI Chatbot (OpenAI) ───────────────────────────────────────────────────────
# OpenAI API key — enables the AI-powered chatbot at POST /api/chat.
# Without this the chatbot falls back to keyword-based rule responses.
# Get your key at: https://platform.openai.com/api-keys
AI_API_KEY=sk-...

# Both variable names are accepted; AI_API_KEY takes precedence.
# OPENAI_API_KEY=sk-...
