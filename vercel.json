{
  "version": 2,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/server.js" },
    { "source": "/admin", "destination": "/api/server.js" },
    { "source": "/admin/", "destination": "/api/server.js" },
    { "source": "/admin.html", "destination": "/api/server.js" },
    { "source": "/admin/login", "destination": "/api/server.js" },
    { "source": "/admin/logout", "destination": "/api/server.js" }
  ]
}